import java.util.Scanner;

public class ex3 {
    public static void main(String[] args) {
        // Entrar coma nota 1 e a nota 2 e o programa
        // exibe na tela a média. Se a  média for menor que 50 imprimir
        // "Reprovado" caso contrário imprimir "Aprovado"
        double n1, n2, media;
        
        System.out.println("Insira as notas separadas por espaço: ");

        Scanner in = new Scanner(System.in);
        n1 = in.nextDouble();
        n2 = in.nextDouble();
        in.close();

        media = (n1+n2/2);

        System.out.println("Média: " + media);

        if(media<50)
            System.out.println("Reprovado");
        else
        System.out.println("Aprovado");

    }
    
}
